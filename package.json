{
  "name": "envy",
  "version": "1.0.0",
  "description": "Version-controlled .env template manager with secret provider integration",
  "main": "dist/index.js",
  "bin": {
    "envy": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts'",
    "restore": "ts-node src/commands/restore.ts"
  },
  "keywords": [
    "env",
    "dotenv",
    "secrets",
    "1password",
    "doppler",
    "template"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
